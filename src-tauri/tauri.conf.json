{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "报销系统",
  "version": "1.0.0",
  "identifier": "com.invoice.system",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000"
  },
  "bundle": {
    "active": true,
    "targets": ["exe"],
    "compact": true,
    "windows": {
      "webviewInstallMode": "embed"
    }
  },
  "app": {
    "windows": [
      {
        "title": "个人报销管理系统",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "security": {
    "csp": null
  }
}
