{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "报销系统",
  "version": "1.0.0",
  "identifier": "com.invoice.system",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3004"
  },
  "app": {
    "windows": [
      {
        "title": "个人报销管理系统",
        "width": 1200,
        "height": 700,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "createAllTargets": false,
    "windows": {
      "wix": false
    }
  }
}
